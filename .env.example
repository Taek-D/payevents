# Supabase 프로젝트 URL (Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase 공개 키 (Settings > API > anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase 서비스 역할 키 (Settings > API > service_role secret) - 서버 전용, 절대 클라이언트에 노출 금지
SUPABASE_SERVICE_ROLE_KEY=

# 사이트 URL (배포 도메인, 예: https://payevents.kr)
NEXT_PUBLIC_BASE_URL=

# 관리자 API 인증 키
ADMIN_SECRET_KEY=
NEXT_PUBLIC_ADMIN_SECRET=
